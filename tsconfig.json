{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "useDefineForClassFields": false,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@v-ibe/core",
    "types": ["vite/client"],
    "paths": {
      // Paths needed for type-checking the framework while it references itself
      "@v-ibe/core": ["./src/index.ts"],
      "@v-ibe/core/jsx-runtime": ["./src/jsx/jsx-runtime.ts"],
      "@v-ibe/core/jsx-dev-runtime": ["./src/jsx/jsx-dev-runtime.ts"],
      "@v-ibe/core/vite-plugins": ["./src/vite-plugins/index.ts"]
    }
  },
  "include": ["src/**/*", "app/**/*"],
  "exclude": ["node_modules", "dist"]
}
